---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p>&copy; {year} Vital Photography</p>
</footer>

<style>
  .site-footer {
    text-align: center;
    padding: 2rem 1.5rem;
    margin-top: 3rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  .site-footer p {
    margin: 0;
  }
</style>
