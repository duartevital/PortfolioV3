<style>
	.about {
		max-width: 640px;
		margin: 0 auto;
		padding: 2rem 1.5rem 4rem;
	}

	.portrait-placeholder {
		width: 160px;
		height: 160px;
		margin: 0 auto 2rem;
		border-radius: 50%;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
	}

	h1 {
		margin-bottom: 0.5rem;
	}

	h2 {
		margin-top: 2rem;
		font-size: 1rem;
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	p {
		line-height: 1.7;
	}
</style>
