---
import BaseLayout from '../layouts/BaseLayout.astro';
import Gallery from '../components/Gallery.vue';
---

<BaseLayout
	title="Vital Photography"
	description="Vital Photography — a landscape, nature, street and urban photography portfolio."
>
	<h1 class="site-title">Vital Photography</h1>
	<Gallery client:load />
</BaseLayout>

<style>
	.site-title {
		text-align: center;
		padding: 2rem 1.5rem 0;
		margin: 0;
		font-weight: 500;
		letter-spacing: 0.02em;
	}
</style>
