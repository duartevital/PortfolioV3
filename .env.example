# SQLite database file path
DATABASE_URL=file:./data/vital.db

# Directory for processed (WebP) images
UPLOADS_DIR=./data/uploads

# base64-encoded bcrypt hash (cost 11) of the admin password - NOT the raw hash.
# This file is read by two mechanisms that disagree about "$": Vite's dotenv-expand
# (local `astro dev`/`astro build`) silently deletes an unescaped `$name` reference;
# Docker's env_file (container runtime) passes values through completely literally.
# There's no single escaping of a raw hash that survives both, so it's base64'd
# instead - base64 has no "$", so it's unaffected either way. Generate with:
#   node -e "console.log(Buffer.from(require('bcryptjs').hashSync('yourpassword', 11)).toString('base64'))"
ADMIN_PASSWORD_HASH=

# Random string >= 32 chars used to sign the session cookie
SESSION_SECRET=

# Canonical site URL, used for SEO/sitemap
PUBLIC_SITE_URL=http://localhost:4321
